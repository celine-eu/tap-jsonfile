# Paths to scan for JSON files (JSON array of glob patterns)
TAP_JSONFILE_PATHS=["data/**/*.json"]

# Stream name (default: records)
TAP_JSONFILE_STREAM_NAME=records

# Number of files to sample for schema inference (default: 20)
TAP_JSONFILE_SAMPLES=20

# S3/MinIO storage credentials (same env vars used by tap-geo)
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY_ID=minioaccess
# S3_SECRET_ACCESS_KEY=miniosecret
